automaton LambdaEjemplo : LNFA {
    alphabet = {a, b}
    states = {q0, q1, q2}
    start = q0
    accept = {q2}
    transitions {
        q0 -> lambda : {q1}
        q1 -> a : {q1}
        q1 -> b : {q2}
    }
};

convert LambdaEjemplo to DFA as DFALambdaEjemplo;

equivalent LambdaEjemplo DFALambdaEjemplo;