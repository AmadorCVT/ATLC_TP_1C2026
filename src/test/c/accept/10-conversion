automaton Uno : DFA {
    alphabet = {a}
    states = {q0}
    start = q0
    accept = {q0}
    transitions {
        q0 -> a : q0
    }
};

automaton Dos : NFA {
    alphabet = {0, 1}
    states = {s0, s1}
    start = s0
    accept = {s1}
    transitions {
        s0 -> 1 : {s0, s1}
    }
};

automaton Tres : LNFA {
    alphabet = {0, 1}
    states = {s0, s1, s3}
    start = s0
    accept = {s3}
    transitions {
        s0 -> lambda : {s1}
        s0 -> 1 : {s0, s1}
    }
};

convert Uno to NFA as UnoNFA;
convert Dos to LNFA as DosNFA;
convert Tres to DFA as TresNFA;